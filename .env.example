# .env.example — Copia como .env y llena los valores
# NUNCA subas .env a GitHub

# ── APIs externas ────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-...
BINANCE_API_KEY=tu_binance_api_key
BINANCE_API_SECRET=tu_binance_api_secret
CRYPTOPANIC_API_KEY=tu_cryptopanic_key

# ── Supabase — Base de datos ─────────────────────────────────
# Project Settings → Database → Connection string → URI (modo Session)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ── Supabase — Autenticación ─────────────────────────────────
# Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=tu_jwt_secret_de_supabase

# ── Solo para el frontend (local) ────────────────────────────
# Project Settings → API → Project URL
SUPABASE_URL=https://TUPROYECTO.supabase.co
# Project Settings → API → anon public key
SUPABASE_ANON_KEY=eyJhbGc...

# ── Render (producción) ──────────────────────────────────────
FRONTEND_URL=https://crypto-analyst-app.onrender.com
